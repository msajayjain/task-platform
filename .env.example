# Shared
NODE_ENV=development

# API
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/task-platform
JWT_ACCESS_SECRET=replace_with_at_least_32_char_secret_for_access_token
JWT_REFRESH_SECRET=replace_with_at_least_32_char_secret_for_refresh_token
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_SALT_ROUNDS=12
REDIS_URL=redis://localhost:6379
FREE_GEMINI_KEY=local_only_mode
FREE_GEMINI_MODEL=gemini-2.0-flash-lite
FREE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent
AI_FALLBACK_PROVIDER=local
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta
HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models
LOCAL_LLM_MODEL=qwen2.5:0.5b
LOCAL_LLM_API_URL=http://127.0.0.1:11434/api/generate
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000
CSRF_SECRET=replace_with_at_least_32_char_csrf_secret_value

# Web/API proxy (web app rewrites /api to this target)
API_PROXY_TARGET=http://localhost:3001
