{
  "name": "@task-platform/api",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate --config ../../prisma.config.ts && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test": "jest --runInBand --config jest.config.js",
    "prisma:generate": "prisma generate --config ../../prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --name init --config ../../prisma.config.ts",
    "prisma:seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.21.0",
    "cookie": "^1.0.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.8.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "jest": "^29.7.0",
    "prisma": "^7.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
